datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model SentinelNode {
  id            String   @id @default(uuid())
  name          String
  address       String   @unique
  status        String   @default("ACTIVE") // ACTIVE, PAUSED, OFFLINE
  latency       String   @default("6.5ms")
  events        Int      @default(0)
  lastHeartbeat DateTime @default(now())
  registeredAt  DateTime @default(now())
}

model Alert {
  id        String   @id @default(uuid())
  txHash    String   @unique
  protocol  String
  type      String
  gasSaved  String
  status    String   // SCANNING, MITIGATED, SAFE
  timestamp String   // e.g. "Just now", "2 mins ago"
  createdAt DateTime @default(now())
}

model AgentLog {
  id        String   @id @default(uuid())
  text      String
  level     String   @default("INFO") // INFO, WARN, ERROR, SUCCESS
  createdAt DateTime @default(now())
}

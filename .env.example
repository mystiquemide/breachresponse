# ==============================================================================
# BreachResponse Environment Variables Example
# ==============================================================================

# Required
# ------------------------------------------------------------------------------
# Mantle Sepolia RPC URL for monitoring mempool and executing rescue payloads
MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz

# Next.js / Wagmi Configuration
NEXT_PUBLIC_WALLETCONNECT_ID=your_walletconnect_project_id_here
NEXT_PUBLIC_REGISTRY_ADDRESS=0xea3C039795B5b04105B795c8B0cB85e0a42Cc85C

# OpenAI API Key for GPT-5.5 payload modeling
OPENAI_API_KEY=sk-proj-your-key-here

# Private Key for the Agent/Sentinel to execute on-chain pause transactions
PRIVATE_KEY=your_private_key_here

# Optional
# ------------------------------------------------------------------------------
LOCAL_RPC_URL=http://127.0.0.1:8545

# BreachResponse environment template
# Copy this file to .env and fill in your own development or testnet values.
# Never commit real private keys, API keys, wallet seeds, or production RPC credentials.

# Mantle RPC endpoint used by the agent and frontend integrations.
MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz
LOCAL_RPC_URL=http://127.0.0.1:8545

# Public frontend values.
NEXT_PUBLIC_WALLETCONNECT_ID=your_walletconnect_project_id_here
NEXT_PUBLIC_REGISTRY_ADDRESS=0xea3C039795B5b04105B795c8B0cB85e0a42Cc85C
NEXT_PUBLIC_MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz
NEXT_PUBLIC_GENLAYER_CONSENSUS_GUARD_ADDRESS=0x86369EC44fbB5EB682729368557176858aBe0c73
NEXT_PUBLIC_GENLAYER_STUDIO_URL=https://studio.genlayer.com/api

# AI provider key used by the local sentinel agent.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=
LLM_MODEL=gpt-4o-mini

# Testnet-only private key for local agent execution.
# Use a dedicated low-balance key. Do not use an exchange, main wallet, multisig owner, or production signer.
PRIVATE_KEY=your_testnet_private_key_here

# Optional controls for deployment environments.
SENTINEL_RESPONSE_MODE=manual
SENTINEL_MAX_ACTION_VALUE=0
SENTINEL_ALLOWED_ACTIONS=pause,quarantine
